<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Compose draws all UI; this is mainly the window background / status bar). -->
    <style name="Theme.NightPOS" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/night_black</item>
        <item name="android:navigationBarColor">@color/night_black</item>
        <item name="android:windowBackground">@color/night_black</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
    </style>

    <!-- Splash-screen theme: shown via androidx.core.splashscreen until Compose content is ready. -->
    <style name="Theme.NightPOS.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/night_black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/night_black</item>
        <item name="postSplashScreenTheme">@style/Theme.NightPOS</item>
    </style>
</resources>
