{
  "manifest_version": 2,
  "name": "NightPOS Polyfill",
  "version": "1.4",
  "description": "Polyfills modern JS APIs and fetches POS config for the NightPOS Android app.",
  "applications": {
    "gecko": {
      "id": "polyfill@nightpos"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.nightpos.com/*"],
      "js": ["pos-configs.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}
