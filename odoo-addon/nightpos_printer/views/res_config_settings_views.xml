<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_nightpos_printer" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.nightpos.printer</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">

            <xpath expr="//setting[@id='pos_other_devices']" position="replace">
                <setting id="nightpos_receipt_printer_setting"
                         string="Receipt Printer (NightPOS)"
                         help="Choose how receipts are printed in the POS session">
                    <field name="pos_nightpos_receipt_mode" widget="radio"/>
                    <field name="pos_nightpos_receipt_device_policy" widget="radio" class="mt-2"/>
                    <div class="content-group mt-2">
                        <field name="pos_nightpos_receipt_printer_id"
                               placeholder="Receipt printer"
                               options="{'no_create': True}"/>
                        <div class="mt-2"
                             invisible="pos_nightpos_receipt_mode not in ('chrome_extension', 'auto')">
                            <label for="pos_nightpos_chrome_printer_name"
                                   string="Windows / local printer"
                                   class="o_form_label"/>
                            <field name="pos_nightpos_chrome_printer_name"
                                   widget="nightpos_chrome_printer"/>
                        </div>
                        <div class="row" invisible="pos_nightpos_receipt_printer_id in [False, '']">
                            <label string="Cashdrawer" for="pos_iface_cashdrawer" class="col-lg-3 o_light_label"/>
                            <field name="pos_iface_cashdrawer"/>
                        </div>
                        
                        <div class="mt-2 d-flex flex-wrap gap-2"
                             invisible="not pos_nightpos_receipt_printer_id">
                            <button name="action_test_nightpos_receipt_printer"
                                    type="object"
                                    string="Test (Shop mode)"
                                    class="btn-link"
                                    icon="fa-print"
                                    title="Test using the shop receipt mode above"/>
                            <button name="action_test_nightpos_receipt_print_odoo"
                                    type="object"
                                    string="Test (Browser / IoT)"
                                    class="btn-link"
                                    icon="fa-print"/>
                            <button name="action_test_nightpos_receipt_print_auto"
                                    type="object"
                                    string="Test (Auto)"
                                    class="btn-link"
                                    icon="fa-print"/>
                            <button name="action_test_nightpos_receipt_print_tcp"
                                    type="object"
                                    string="Test (TCP)"
                                    class="btn-link"
                                    icon="fa-print"/>
                            <button name="action_test_nightpos_receipt_print_sunmi"
                                    type="object"
                                    string="Test (Sunmi)"
                                    class="btn-link"
                                    icon="fa-print"/>
                            <button name="action_test_nightpos_receipt_print_chrome"
                                    type="object"
                                    string="Test (Chrome)"
                                    class="btn-link"
                                    icon="fa-print"/>
                        </div>
                    </div>
                    <div role="alert" class="alert alert-info"
                         invisible="pos_nightpos_receipt_mode != 'sunmi'">
                        Uses the built-in Sunmi printer via the NightPOS Android app.
                        Configure paper width and options on the POS shop form.
                    </div>
                    <div role="alert" class="alert alert-warning"
                         invisible="not pos_iface_print_via_proxy or pos_nightpos_receipt_mode != 'tcp' or pos_nightpos_receipt_printer_id in [False, '']">
                        The receipt printer will be used instead of the receipt printer connected to the IoT Box.
                    </div>
                </setting>
            </xpath>

            <xpath expr="//setting[@id='is_order_printer']" position="replace">
                <setting id="nightpos_preparation_printer_setting"
                         string="Preparation Printers"
                         help="Print orders at the kitchen, at the bar, etc. using NightPOS TCP printers">
                    <field name="pos_nightpos_preparation_enabled"/>
                    <div class="content-group" invisible="not pos_nightpos_preparation_enabled">
                        
                        <div class="mt16 mb-1">
                            <label string="Printers"
                                   for="pos_nightpos_preparation_printer_ids"
                                   class="o_light_label me-2"/>
                            <field name="pos_nightpos_preparation_printer_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </div>
                        <div>
                            <button name="action_pos_printer_dialog"
                                    type="object"
                                    icon="oi-arrow-right"
                                    string="Add Printer"
                                    class="btn-link"/>
                        </div>
                        <div>
                            <button name="action_open_nightpos_printer_list"
                                    type="object"
                                    icon="oi-arrow-right"
                                    string="Manage Printers"
                                    class="btn-link"/>
                        </div>
                    </div>
                </setting>
            </xpath>

            <!-- Hide AvaTax PoS (point_of_sale → base settings form) -->
            <xpath expr="//setting[@id='pos-avatax']" position="replace"/>

            <!-- Hide regional payment terminals not used by NightPOS (Odoo 19: use field/id selectors, not @string) -->
            <xpath expr="//block[@id='pos_payment_terminals_section']//setting[@id='adyen_payment_terminal_setting']" position="replace"/>
            <xpath expr="//block[@id='pos_payment_terminals_section']//setting[.//field[@name='module_pos_viva_com']]" position="replace"/>
            <xpath expr="//block[@id='pos_payment_terminals_section']//setting[@id='pos_razorpay_setting']" position="replace"/>
            <xpath expr="//block[@id='pos_payment_terminals_section']//setting[.//field[@name='module_pos_mercado_pago']]" position="replace"/>
            <xpath expr="//block[@id='pos_payment_terminals_section']//setting[.//field[@name='module_pos_pine_labs']]" position="replace"/>
            <xpath expr="//block[@id='pos_payment_terminals_section']//setting[.//field[@name='module_pos_qfpay']]" position="replace"/>

        </field>
    </record>

</odoo>
