<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="nightpos_device_print_view_list" model="ir.ui.view">
        <field name="name">nightpos.device.print.list</field>
        <field name="model">nightpos.device.print</field>
        <field name="arch" type="xml">
            <list string="Device print profiles" create="0">
                <field name="pos_config_id"/>
                <field name="name"/>
                <field name="device_key"/>
                <field name="receipt_mode"/>
                <field name="chrome_printer_name" optional="show"/>
                <field name="nightpos_receipt_printer_id" optional="show"/>
                <field name="last_seen"/>
                <field name="user_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_nightpos_device_print" model="ir.actions.act_window">
        <field name="name">Device print profiles</field>
        <field name="res_model">nightpos.device.print</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_nightpos_device_print"
              name="Device print profiles"
              parent="menu_nightpos_configuration"
              action="action_nightpos_device_print"
              sequence="25"
              groups="point_of_sale.group_pos_manager"/>
</odoo>
