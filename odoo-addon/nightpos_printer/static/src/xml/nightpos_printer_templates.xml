<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!--
        TestPrintDialog — OWL 3 / Odoo 19 compatible
        Uses t-set-slot="footer" for custom footer buttons
    -->
    <t t-name="nightpos_printer.TestPrintDialog">
        <Dialog title="'ทดสอบพิมพ์'" size="'md'">

            <!-- ── Body ── -->
            <div class="d-flex flex-column align-items-center py-3 gap-3">

                <!-- Spinner while working -->
                <t t-if="state.phase === 'testing' or state.phase === 'printing'">
                    <div class="spinner-border text-primary" role="status"
                         style="width:3rem;height:3rem;">
                        <span class="visually-hidden">กำลังดำเนินการ...</span>
                    </div>
                </t>

                <!-- Success -->
                <t t-elif="state.phase === 'ok'">
                    <i class="fa fa-check-circle text-success" style="font-size:3rem;"/>
                </t>

                <!-- Error / no_app -->
                <t t-elif="state.phase === 'error' or state.phase === 'no_app'">
                    <i class="fa fa-times-circle text-danger" style="font-size:3rem;"/>
                </t>

                <!-- Message -->
                <p class="text-center mb-0 fw-semibold"
                   style="white-space:pre-line;"
                   t-esc="state.message"/>

                <!-- Printer info -->
                <div class="alert alert-light border w-100 mb-0"
                     style="font-size:0.82rem;">
                    <strong>พริ้นเตอร์: </strong><t t-esc="props.name"/>
                    <t t-if="props.shop_mode === 'sunmi'">
                        <br/>
                        <strong>ประเภท: </strong>Sunmi built-in (ไม่ใช้ IP)
                    </t>
                    <t t-else="">
                        <br/>
                        <strong>IP: </strong><t t-esc="props.ip or '—'"/>
                        <strong class="ms-2">Port: </strong><t t-esc="props.port"/>
                    </t>
                </div>

            </div>

            <!-- ── Footer (custom slot) ── -->
            <t t-set-slot="footer">
                <t t-if="state.phase === 'ok'">
                    <button class="btn btn-primary" t-on-click="props.close">
                        ตกลง
                    </button>
                </t>
                <t t-elif="state.phase === 'error' or state.phase === 'no_app'">
                    <button class="btn btn-secondary" t-on-click="props.close">
                        ปิด
                    </button>
                </t>
                <t t-else="">
                    <button class="btn btn-secondary" disabled="true">
                        กำลังดำเนินการ...
                    </button>
                </t>
            </t>

        </Dialog>
    </t>

    <t t-name="nightpos_printer.ChromePrinterField">
        <div class="o_field_nightpos_chrome_printer d-flex flex-column gap-2">
            <div class="d-flex flex-wrap align-items-center gap-2">
                <select class="form-select flex-grow-1"
                        t-att-disabled="props.readonly or state.loading"
                        t-att-value="value"
                        t-on-change="onSelectChange">
                    <option value="">— Default Windows printer —</option>
                    <t t-foreach="state.printers" t-as="printer" t-key="printer">
                        <option t-att-value="printer"
                                t-att-selected="printer === value ? 'selected' : None"
                                t-esc="printer"/>
                    </t>
                </select>
                <button type="button"
                        class="btn btn-secondary"
                        t-att-disabled="state.loading"
                        t-on-click="loadPrinters">
                    <i t-attf-class="fa fa-refresh {{ state.loading ? 'fa-spin' : '' }}"/>
                    <span class="ms-1">Refresh</span>
                </button>
            </div>
            <t t-if="state.error">
                <div class="alert alert-warning mb-0 py-2" role="alert" style="font-size:0.85rem;">
                    <t t-esc="state.error"/>
                </div>
            </t>
            <t t-elif="!state.printers.length and !state.loading">
                <p class="text-muted mb-0" style="font-size:0.85rem;">
                    Click Refresh to load printers from the local print server
                    (<code>ws://localhost:8765</code>). Names must match Windows
                    <em>Devices and Printers</em> exactly.
                </p>
            </t>
        </div>
    </t>

    <t t-name="nightpos_printer.LocalPrintTestDialog">
        <Dialog title="'Chrome Extension Print'" size="'md'">
            <div class="d-flex flex-column align-items-center py-3 gap-3">
                <t t-if="state.phase === 'ok'">
                    <i class="fa fa-check-circle text-success" style="font-size:3rem;"/>
                </t>
                <t t-elif="state.phase === 'error'">
                    <i class="fa fa-times-circle text-danger" style="font-size:3rem;"/>
                </t>
                <t t-else="">
                    <div class="spinner-border text-primary" role="status"
                         style="width:3rem;height:3rem;"/>
                </t>
                <p class="text-center mb-0 fw-semibold"
                   style="white-space:pre-line;"
                   t-esc="state.message"/>
                <div class="alert alert-light border w-100 mb-0" style="font-size:0.82rem;">
                    <strong>Printer: </strong><t t-esc="props.printer_name"/>
                    <br/>
                    <strong>Protocol: </strong><t t-esc="props.protocol or 'escpos'"/>
                    <strong class="ms-2">Encoding: </strong><t t-esc="props.encoding or 'base64'"/>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="props.close">
                    Close
                </button>
            </t>
        </Dialog>
    </t>

    <t t-name="nightpos_printer.DevicePrintConfigPopup">
        <Dialog title="'This device — printer'" size="'md'">
            <div class="d-flex flex-column gap-3">
                <div class="alert alert-info mb-0 py-2" role="alert">
                    Settings here apply only to <strong>this</strong> tablet or PC
                    (saved in the database). Changing Receipt Printer on the shop form
                    affects all devices unless you use per-device policy.
                </div>
                <div class="text-muted small">
                    Device id: <code t-esc="deviceKeyShort"/>
                </div>
                
                <div>
                    <label class="form-label fw-bold" for="np_device_print_mode">Printer type</label>
                    <select id="np_device_print_mode"
                            class="form-select"
                            t-att-value="state.receipt_mode"
                            t-on-change="onModeChange">
                        <t t-foreach="modeOptions" t-as="opt" t-key="opt.value">
                            <option t-att-value="opt.value" t-esc="opt.label"/>
                        </t>
                    </select>
                </div>
                
                <div t-if="showTcpPrinter">
                    <label class="form-label fw-bold" for="np_device_tcp_printer">TCP / Sunmi printer record</label>
                    <select id="np_device_tcp_printer"
                            class="form-select"
                            t-att-value="state.nightpos_receipt_printer_id"
                            t-on-change="onPrinterChange">
                        <option value="">— Shop default —</option>
                        <t t-foreach="printerOptions" t-as="printer" t-key="printer.id">
                            <option t-att-value="printer.id" t-esc="printer.name"/>
                        </t>
                    </select>
                </div>
                
                
                <div t-if="showChromePrinter">
                    <label class="form-label fw-bold" for="np_device_chrome_printer">Windows / local printer</label>
                    <select id="np_device_chrome_printer"
                            class="form-select"
                            t-att-disabled="state.loadingChrome"
                            t-att-value="state.chrome_printer_name"
                            t-on-change="onChromeChange">
                        <option value="">— Select —</option>
                        <t t-foreach="state.chromePrinters" t-as="name" t-key="name">
                            <option t-att-value="name" t-esc="name"/>
                        </t>
                    </select>
                    <div t-if="state.loadingChrome" class="text-muted small mt-1">Loading local printers…</div>
                </div>
                
                <div>
                    <label class="form-label" for="np_device_label">Device label (optional)</label>
                    <input id="np_device_label"
                           type="text"
                           class="form-control"
                           t-att-value="state.name"
                           t-on-input="onNameChange"
                           placeholder="e.g. Counter tablet, Kitchen PC"/>
                </div>
                
                <div t-if="state.error" class="alert alert-danger mb-0" role="alert" t-esc="state.error"/>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="onDiscard" t-att-disabled="state.saving">
                    Discard
                </button>
                <button class="btn btn-primary" t-on-click="onSave" t-att-disabled="state.saving">
                    <t t-if="state.saving">Saving…</t>
                    <t t-else="">Save for this device</t>
                </button>
            </t>
        </Dialog>
    </t>

</templates>
