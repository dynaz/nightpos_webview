<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Avoid crash when pos.config.company_id was missing from a partial POS data load -->
    <t t-name="nightpos_printer.LoginScreen" t-inherit="point_of_sale.LoginScreen" t-inherit-mode="extension">
        <xpath expr="//img[contains(@t-attf-src, 'res.company')]" position="replace">
            <img t-if="pos.company?.id"
                 t-attf-src="/web/image?model=res.company&amp;id={{pos.company.id}}&amp;field=logo"
                 alt="Logo"/>
        </xpath>
        <xpath expr="//div[button[hasclass('select-logout')]]" position="attributes">
            <attribute name="class" add="gap-2" separator=" "/>
        </xpath>
        <xpath expr="//button[hasclass('select-logout')]" position="before">
            <button t-if="showDevicePrintButton"
                    class="select-device-print btn btn-secondary btn-lg"
                    t-on-click="() => this.openDevicePrintSettings()">
                <span class="d-flex flex-grow-1 align-items-center" t-esc="devicePrintButtonLabel"/>
            </button>
        </xpath>
    </t>
</templates>
